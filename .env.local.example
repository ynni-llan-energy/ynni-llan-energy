# ============================================================
# Ynni Cymunedol Llanfairfechan — Environment Variables
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and never committed.
# ============================================================

# Supabase — get these from the Supabase dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Sanity — get these from sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your-sanity-project-id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your-sanity-api-token
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NEXT_PUBLIC_ prefix is required — sanity.config.ts runs in the browser
NEXT_PUBLIC_SANITY_PREVIEW_SECRET=your-preview-secret

# Resend — get this from resend.com > API Keys
RESEND_API_KEY=re_your-resend-api-key
